# --- Waitlist (public form + admin dashboard) ---
# Supabase: SQL Editor → run:
#   create table waitlist_signups (
#     id uuid primary key default gen_random_uuid(),
#     name text not null,
#     email text not null,
#     specialty text not null,
#     created_at timestamptz not null default now()
#   );
# Use Project URL + service_role key (server only; never expose to the client).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Local dev only: store signups in server memory (lost on restart). Do not use in production.
WAITLIST_DEV_MEMORY_STORE=1

# Password for /admin/login — use a long random value in production.
WAITLIST_ADMIN_SECRET=
